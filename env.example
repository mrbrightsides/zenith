# ZENITH LIVE - Environment Variables Example

# Google AI Studio (Required for Gemini 3.1 Pro, Imagen 3, Veo 3.1)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (Required for Agentic Memory)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Auth0 Configuration (Required for Authorized to Act & Trust Circle)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# WebSocket Server (Optional, defaults to current host)
VITE_WS_URL=ws://localhost:3000
